# ─── Database (Supabase PostgreSQL via connection pooler) ─────────────────────
DATABASE_URL=postgresql://postgres.project:password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Set to your Vercel deployment URL in production (e.g. https://pledgepay.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# ─── Flutterwave (Payment Gateway) ────────────────────────────────────────────
NEXT_PUBLIC_FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Nodemailer — Gmail SMTP ──────────────────────────────────────────────────
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM=PledgePay <your-email@gmail.com>

# ─── Supabase (file storage) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron (optional — for Vercel Cron Jobs) ───────────────────────────────────
CRON_SECRET=your-cron-secret-here
